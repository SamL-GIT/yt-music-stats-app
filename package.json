{
  "name": "yt-music-stats-electron",
  "version": "1.1.6",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "cheerio": "^1.2.0",
    "fastify": "^5.7.4"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ytmusicstats.app",
    "productName": "YT Music Stats",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Audio",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "index.html",
      "package.json",
      "icon.png"
    ]
  }
}